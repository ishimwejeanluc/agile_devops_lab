{
  "name": "url-shortener",
  "version": "1.0.0",
  "description": "URL Shortener API — Sprint 2 increment (custom codes, stats, health, logging)",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "test": "jest --coverage --verbose"
  },
  "dependencies": {
    "express": "^4.19.2",
    "nanoid": "^3.3.7",
    "valid-url": "^1.0.9"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": ["src/**/*.js", "!src/server.js"],
    "coverageThreshold": {
      "global": {
        "statements": 95,
        "branches": 85,
        "functions": 90,
        "lines": 95
      }
    }
  },
  "engines": { "node": ">=18.0.0" }
}
